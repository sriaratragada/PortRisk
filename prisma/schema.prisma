generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  createdAt  DateTime    @default(now())
  portfolios Portfolio[]
  auditLogs  AuditLog[]
}

model Portfolio {
  id          String       @id @default(uuid())
  userId      String
  name        String
  benchmark   String       @default("SPY")
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  positions   Position[]
  watchlistItems WatchlistItem[]
  riskScores  RiskScore[]
  riskInsights RiskInsight[]
  stressTests StressTest[]
  auditLogs   AuditLog[]
  user        User         @relation(fields: [userId], references: [id])
}

model Position {
  id          String    @id @default(uuid())
  portfolioId String
  ticker      String
  shares      Float
  avgCost     Float
  assetClass  String    @default("equities")
  addedAt     DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
  @@index([portfolioId])
}

model WatchlistItem {
  id             String    @id @default(uuid())
  portfolioId    String
  ticker         String
  companyName    String
  exchange       String
  quoteType      String
  sector         String
  industry       String?
  status         String    @default("NEW")
  conviction     Int       @default(3)
  targetPrice    Float?
  thesis         String    @default("")
  catalysts      String    @default("")
  risks          String    @default("")
  valuationNotes String    @default("")
  notes          String    @default("")
  sourceType     String    @default("manual")
  sourceLabel    String    @default("Manual search")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, updatedAt(sort: Desc)])
  @@index([portfolioId, status, updatedAt(sort: Desc)])
}

model RiskScore {
  id               String    @id @default(uuid())
  portfolioId      String
  scoredAt         DateTime  @default(now())
  sharpe           Float
  maxDrawdown      Float
  var95            Float
  var95Amount      Float
  drawdownProb3m   Float
  drawdownProb6m   Float
  drawdownProb12m  Float
  riskTier         String
  summary          String
  inputs           Json
  portfolio        Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, scoredAt(sort: Desc)])
}

model RiskInsight {
  id                String    @id @default(uuid())
  portfolioId       String
  generatedAt       DateTime  @default(now())
  sourceRiskScoreId String?
  model             String
  provider          String
  source            String
  summary           String
  drivers           Json
  resilienceFactors Json
  alerts            Json
  recommendedActions Json
  regimeCommentary  String
  changeSummary     String
  dataConfidence    String
  rawPromptInput    Json
  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, generatedAt(sort: Desc)])
}

model StressTest {
  id                  String    @id @default(uuid())
  portfolioId         String
  scenarioName        String
  runAt               DateTime  @default(now())
  projectedValue      Float
  newRiskTier         String
  recoveryDays        Int
  inputs              Json
  results             Json
  portfolio           Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, runAt(sort: Desc)])
}

model AuditLog {
  id              String    @id @default(uuid())
  userId          String
  portfolioId     String
  timestamp       DateTime  @default(now())
  eventVersion    Int       @default(2)
  actionType      String
  category        String    @default("SYSTEM")
  severity        String    @default("INFO")
  outcome         String    @default("SUCCESS")
  actorType       String    @default("USER")
  requestId       String?
  route           String?
  method          String?
  sessionId       String?
  ipHash          String?
  userAgentHash   String?
  reasonCode      String?
  controlRefs     Json?
  policyEvaluations Json?
  prevEventHash   String?
  eventHash       String?
  beforeState     Json
  afterState      Json
  riskTierBefore  String?
  riskTierAfter   String?
  metadata        Json?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp(sort: Desc)])
  @@index([portfolioId, timestamp(sort: Desc)])
  @@index([userId, portfolioId, timestamp(sort: Desc)])
  @@index([category, severity, outcome, timestamp(sort: Desc)])
  @@index([requestId])
}

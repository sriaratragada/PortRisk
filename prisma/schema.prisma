generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String      @id @default(uuid())
  email      String      @unique
  createdAt  DateTime    @default(now())
  portfolios Portfolio[]
  auditLogs  AuditLog[]
}

model Portfolio {
  id          String       @id @default(uuid())
  userId      String
  name        String
  archivedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  positions   Position[]
  riskScores  RiskScore[]
  riskInsights RiskInsight[]
  stressTests StressTest[]
  auditLogs   AuditLog[]
  user        User         @relation(fields: [userId], references: [id])
}

model Position {
  id          String    @id @default(uuid())
  portfolioId String
  ticker      String
  shares      Float
  avgCost     Float
  assetClass  String    @default("equities")
  addedAt     DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@unique([portfolioId, ticker])
  @@index([portfolioId])
}

model RiskScore {
  id               String    @id @default(uuid())
  portfolioId      String
  scoredAt         DateTime  @default(now())
  sharpe           Float
  maxDrawdown      Float
  var95            Float
  var95Amount      Float
  drawdownProb3m   Float
  drawdownProb6m   Float
  drawdownProb12m  Float
  riskTier         String
  summary          String
  inputs           Json
  portfolio        Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, scoredAt(sort: Desc)])
}

model RiskInsight {
  id                String    @id @default(uuid())
  portfolioId       String
  generatedAt       DateTime  @default(now())
  sourceRiskScoreId String?
  model             String
  provider          String
  source            String
  summary           String
  drivers           Json
  resilienceFactors Json
  alerts            Json
  recommendedActions Json
  regimeCommentary  String
  changeSummary     String
  dataConfidence    String
  rawPromptInput    Json
  portfolio         Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, generatedAt(sort: Desc)])
}

model StressTest {
  id                  String    @id @default(uuid())
  portfolioId         String
  scenarioName        String
  runAt               DateTime  @default(now())
  projectedValue      Float
  newRiskTier         String
  recoveryDays        Int
  inputs              Json
  results             Json
  portfolio           Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([portfolioId, runAt(sort: Desc)])
}

model AuditLog {
  id              String    @id @default(uuid())
  userId          String
  portfolioId     String
  timestamp       DateTime  @default(now())
  actionType      String
  beforeState     Json
  afterState      Json
  riskTierBefore  String?
  riskTierAfter   String?
  metadata        Json?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio       Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp(sort: Desc)])
  @@index([portfolioId, timestamp(sort: Desc)])
}

model MarketQuoteCache {
  symbol           String   @id
  price            Float
  previousClose    Float
  changePercent    Float
  currency         String
  shortName        String?
  longName         String?
  exchange         String?
  marketCap        Float?
  trailingPE       Float?
  fiftyTwoWeekLow  Float?
  fiftyTwoWeekHigh Float?
  provider         String
  asOf             DateTime
  fetchedAt        DateTime @updatedAt
  rawPayload       Json
}

model MarketHistoryCache {
  id         String   @id @default(uuid())
  symbol     String
  range      String
  series     Json
  provider   String
  asOf       DateTime
  fetchedAt  DateTime @updatedAt
  seriesStart DateTime?
  seriesEnd   DateTime?
  rawPayload Json

  @@unique([symbol, range])
}

model SecurityIdentityCache {
  symbol     String   @id
  provider   String
  asOf       DateTime
  fetchedAt  DateTime @updatedAt
  data       Json
  rawPayload Json
}
